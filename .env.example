# Select the backend model provider.
# Supported: gemini, volcengine, openai-compatible
AI_PROVIDER="gemini"

# Gemini / Google AI Studio
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-3.5-flash"

# Volcengine Ark (火山引擎方舟), OpenAI-compatible Chat Completions API.
# VOLCENGINE_MODEL is usually your Ark endpoint ID or model endpoint name.
# The default base URL is https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_API_KEY="MY_VOLCENGINE_ARK_API_KEY"
VOLCENGINE_MODEL="MY_ARK_ENDPOINT_ID"
VOLCENGINE_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"

# Any other OpenAI-compatible provider.
OPENAI_COMPATIBLE_API_KEY="MY_PROVIDER_API_KEY"
OPENAI_COMPATIBLE_BASE_URL="https://provider.example.com/v1"
OPENAI_COMPATIBLE_MODEL="provider-model-name"

# Optional generation tuning.
AI_TEMPERATURE="0.85"
AI_MAX_TOKENS="2000"

# Optional upstream network hardening for OpenAI-compatible providers.
AI_REQUEST_RETRIES="3"
AI_CONNECT_TIMEOUT_MS="25000"
AI_HEADERS_TIMEOUT_MS="90000"
AI_BODY_TIMEOUT_MS="240000"
AI_RETRY_BASE_DELAY_MS="900"
